# YAPU Environment Variables
# Copy this file to .env.local on the VPS and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Content API authentication — used by app/api/content/route.ts
# Generate with: openssl rand -base64 32
CONTENT_API_SECRET=your-secret-token-here

# Preview access token — used in nginx-yapu-preview.conf bearer check
# Generate with: openssl rand -base64 32
# Must also be set in /etc/nginx/sites-available/yapu-preview (replace PREVIEW_ACCESS_TOKEN_PLACEHOLDER)
PREVIEW_ACCESS_TOKEN=your-preview-token-here
